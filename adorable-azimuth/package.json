    "@astrojs/preact": "^4.1.3",
    "@astrojs/vercel": "^9.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.6",
    "gsap": "^3.12.5",
    "preact": "^10.28.1",
    "tailwindcss": "^4.1.18",
