  contactTitle: "Contato",
  contactHeadlineHtml: "Quer tirar sua ideia do papel com <em>engenharia bem feita?</em>",
  contactBody: "Me conte contexto, restrições e objetivo. Eu retorno com perguntas técnicas e um caminho de execução.",
  contactPrimaryCta: "WhatsApp ↗",
  contactSecondaryCta: "LinkedIn ↗",
  backTop: "Voltar ao topo ↑"
