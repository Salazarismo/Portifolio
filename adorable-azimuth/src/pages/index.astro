---
<BaseLayout title="Victor de Alcântara Bueno — Engenheiro de Software" description="Construo produtos web e mobile com foco em performance, clareza de arquitetura e entrega previsível.">
  <Fragment slot="nav">
    <a href="/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href={`#${data.projectsId}`}>Projetos</a>
      <a href={`#${data.aboutId}`}>Sobre</a>
      <a href={`#${data.contactId}`}>Contato</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">Disponível 2026</span>
      <a href="/" class="lang-active">PT</a>
      <a href="/en/">EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <div id="top"></div>
  <HomeLandingRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-id">
      <span class="footer-name">Victor de Alcântara Bueno</span>
      <span class="footer-role">Engenheiro de Software</span>
    </div>
    <div class="footer-links">
      <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
      <a href="https://github.com/Salazarismo">GitHub</a>
      <a href="https://wa.me/5548984586949">WhatsApp</a>
    </div>
    <span class="footer-copy">© 2026 Victor</span>
  </Fragment>
</BaseLayout>
