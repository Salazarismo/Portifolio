      badge: "Tempo",
      titleHtml: "Relatorium<br/><em style='font-style:italic;color:var(--text-dim);font-family:var(--serif);font-weight:300'>Quick Activity Button</em>",
      kpi: "45s → 20–25s no registro — −40–55% de cliques no fluxo.",
      tags: ["Mobile + UX", "Tempo 45–60%"],
      cta: "Ver case"
    }
  ],
  aboutTitle: "Sobre",
  aboutTextHtml: "Trabalho com <strong>front-end, back-end e mobile</strong>, com prioridade em clareza de arquitetura, acessibilidade e métricas de produto. Já atuei em projetos privados em produção e em iniciativas open-source, sempre buscando <strong>reduzir fricção</strong> e aumentar <strong>previsibilidade de entrega</strong>.",
  aboutTechLabel: "Tecnologias frequentes",
  aboutFindMeLabel: "Encontre-me em",
  aboutLinks: [
    { label: "LinkedIn ↗", href: "https://www.linkedin.com/in/victor-de-alcantara/" },
    { label: "GitHub ↗", href: "https://github.com/Salazarismo" }
