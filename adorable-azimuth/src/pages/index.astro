---
import BaseLayout from "../components/BaseLayout.astro";
import HomeHybridLanding from "../components/HomeHybridLanding.astro";

const data = {
  logoHref: "/",
  ptHref: "/",
  enHref: "/en/",
  isEN: false,
  eyebrow: "Engenheiro de Software",
  title: "Full-Stack · Offline-First · Integrações Críticas",
  description: "Construo produtos web e mobile com foco em confiabilidade operacional, experiência consistente em campo e integrações que não falham sob pressão.",
  recruiterTag: "→ Recrutadores & Gestores",
  recruiterHeadline: "Estou em busca de uma vaga",
  recruiterSub: "Currículo, cases técnicos e perfil profissional completo.",
  recruiterArrow: "Ver perfil profissional →",
  recruiterHref: "/recruiter",
  clientTag: "→ Clientes & Projetos",
  clientHeadline: "Tenho um projeto em mente",
  clientSub: "Cases, stack, abordagem e contato direto para escopo.",
  clientArrow: "Ver projetos →",
  clientHref: "/client",
  footerEmailLabel: "Email",
  footerCopy: "© 2026 Victor de Alcântara Bueno"
};
---
<BaseLayout
  title="Victor de Alcântara Bueno — Engenheiro de Software"
  description="Engenheiro de Software especializado em produtos offline-first, integrações críticas e UX operacional."
>
  <Fragment slot="nav">
    <a class="nav-logo" href={data.logoHref}>Victor<span>®</span></a>
    <div class="nav-lang">
      <a href={data.ptHref} class="active">PT</a>
      <span>/</span>
      <a href={data.enHref}>EN</a>
    </div>
  </Fragment>

  <HomeHybridLanding {...data} />

  <Fragment slot="footer">
    <div class="footer-links">
      <a href="https://linkedin.com/in/victor-de-alcantara/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/Salazarismo" target="_blank" rel="noopener">GitHub</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">{data.footerEmailLabel}</a>
    </div>
    <span class="footer-copy">{data.footerCopy}</span>
  </Fragment>
</BaseLayout>
