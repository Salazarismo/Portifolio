---
import BaseLayout from "../components/BaseLayout.astro";
import HomeLandingRedesign from "../components/HomeLandingRedesign.astro";

const data = {
  projectsId: "projects",
  aboutId: "sobre",
  contactId: "contato",
  heroEyebrow: "Engenheiro de Software",
  heroNameTop: "Victor de<br/>Alcântara",
  heroNameEm: "Bueno",
  heroRole: "Disponível para projetos em 2026",
  heroTagline: "Construo produtos web e mobile com foco em performance, clareza de arquitetura e entrega previsível.",
  heroPrimaryCta: "Ver projetos ↓",
