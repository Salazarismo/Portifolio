      image: "https://victor-alcantara.vercel.app/images/analytics-code.svg",
      alt: "Habit Analyzer — analytics",
      year: "2023",
      badge: "Custo",
      titleHtml: "Habit Analyzer",
      kpi: "−40% custo de leitura de analytics em janelas grandes.",
