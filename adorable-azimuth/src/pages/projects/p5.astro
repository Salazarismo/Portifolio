---
import BaseLayout from "../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Case de Produto",
  heroTitleTop: "Relatorium",
  heroTitleEm: "UI Quick Activity Button",
  heroSubtitle: "Aplicativo Flutter para gestão rural com dashboard e atalhos rápidos para iniciar fluxos — atividades, solo, orçamento e mais.",
  heroImage: "https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fm=jpg&w=1600&q=80",
  heroFilter: "grayscale(.8) brightness(.25)",
  langPT: "/projects/p5/",
  langEN: "/en/projects/p5/",
  availLabel: "Disponível 2026",
  isEN: false,
  heroStats: [
    { key: "Escopo", value: "UI Component + Dashboard" },
    { key: "Stack", value: "Flutter · go_router" },
    { key: "Código", value: "Privado (NDA)" },
    { key: "Atalhos críticos", value: "6 ações em 1 clique" }
  ],
  heroActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Ver Evidências", href: "#evidence" },
    { label: "Código Privado (NDA)", href: "#code" }
  ],
  tldrTitle: "TL;DR — 1 minuto",
  tldrCards: [
    { key: "Problema", value: "Iniciar fluxos frequentes — atividade, solo, orçamento — exigia <strong>navegação adicional</strong> antes de chegar na ação." },
    { key: "Solução", value: "Atalhos padronizados com <strong>QuickActionButton</strong> + Semantics + Tooltip e navegação por rotas nomeadas (go_router)." },
    { key: "Resultado", value: "Dashboard com <strong>entradas rápidas consistentes e acessíveis</strong> para criar registros e acessar telas-chave." }
  ],
  noticeTitle: "Código privado (NDA).",
  noticeBody: "Este software está em produção e sob propriedade de uma empresa. Acesso a material sanitizado pode ser solicitado diretamente.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Papel / escopo", value: "Flutter multiplataforma. Escopo: componente UI + integração no dashboard." },
    { key: "Escala", value: "Dashboard com atalhos para múltiplos módulos — Atividades, Solo, Financeiro, Pragas & Doenças." },
    { key: "Restrições", value: "Acessibilidade (Semantics), feedback (Tooltip) e navegação consistente via rotas nomeadas." }
  ],
  problemTitle: "Problema & Impacto",
  problemItems: [
    { key: "Sintoma", value: "Ações de criação e acesso rápido ficavam <strong>distribuídas entre telas e menus</strong>, atrasando o início do fluxo." },
    { key: "Causa", value: "Ausência de um <strong>padrão de atalhos reutilizáveis</strong> com navegação consistente no dashboard." },
    { key: "Impacto", value: "Mais passos para iniciar registros frequentes e <strong>maior chance de desvio de navegação</strong>." }
  ],
  approachTitle: "Abordagem",
  approachSteps: [
    { title: "Identificar", text: "Mapear as ações que iniciam fluxos frequentes no dashboard — criar atividade, análise de solo, orçamento — e priorizá-las por frequência de uso." },
    { title: "Encapsular", text: "Consolidar em um <code style='font-family:var(--mono);font-size:.85em;color:var(--amber-soft)'>QuickActionButton</code> com Semantics e Tooltip — padrão único de UI + acessibilidade, reutilizável em qualquer módulo." },
    { title: "Navegar", text: "Integrar rotas nomeadas via go_router para manter previsibilidade e eliminar ambiguidade na navegação entre telas." }
  ],
  reliabilityTitle: "Confiabilidade",
  reliabilityCards: [
    { key: "Riscos", value: "Atalhos invisíveis para acessibilidade, navegação inconsistente, regressão no fluxo." },
    { key: "Garantias", value: "Semantics define papel e rótulo; Tooltip dá contexto; rotas nomeadas reduzem desvios." },
    { key: "Evidência", value: "Implementação do componente e uso no DashboardPage com pushNamed para rotas nomeadas." }
  ],
  codeBlock: {
    lang: "Dart · Flutter",
    html: `<span class="kw">Semantics</span><span class="pu">(</span>
  button<span class="pu">:</span> <span class="kw">true</span><span class="pu">,</span>
  label<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
  child<span class="pu">:</span> <span class="kw">Tooltip</span><span class="pu">(</span>
    message<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
    child<span class="pu">:</span> <span class="fn">QuickActionButton</span><span class="pu">(</span>
      label<span class="pu">:</span>          <span class="str">'Nova atividade'</span><span class="pu">,</span>
      icon<span class="pu">:</span>           Icons<span class="pu">.</span>event_available<span class="pu">,</span>
      semanticsLabel<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
      onPressed<span class="pu">:</span> <span class="pu">()</span> <span class="pu">=></span> context<span class="pu">.</span><span class="fn">pushNamed</span><span class="pu">(</span>AppRoutes<span class="pu">.</span>newActivity<span class="pu">),</span>
    <span class="pu">),</span>
  <span class="pu">),</span>
<span class="pu">);</span>`
  },
  stackTags: ["Flutter", "Semantics", "Tooltip", "go_router", "Rotas nomeadas"],
  extensionsTitle: "Extensões & Próximos passos",
  extensionsItems: [
    "Permitir configuração dos atalhos do dashboard — quais ações aparecem e em que ordem.",
    "Adicionar atalhos de teclado/foco para desktop sem perder consistência com mobile.",
    "Expandir testes de widget cobrindo Semantics, Tooltip e navegação por rotas nomeadas."
  ],
  ctaEyebrow: "Você tem esse problema?",
  ctaTitle: "Precisa reduzir passos no dia a dia sem quebrar acessibilidade?",
  ctaBody: "Eu redesenho fluxos e implemento atalhos reutilizáveis com navegação consistente — e entrego evidências de cada decisão.",
  ctaActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Código (NDA)", href: "#code" },
    { label: "Evidências", href: "#evidence" }
  ],
  bottomNavBackLabel: "Voltar",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Topo",
  bottomNavNextLabel: "Próximo case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p7/"
};
---
<BaseLayout title="Relatorium — UI Quick Activity Button — Victor de Alcântara" description="Aplicativo Flutter para gestão rural com dashboard e atalhos rápidos para iniciar fluxos.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="/#projects">Projetos</a>
      <a href="/#sobre">Sobre</a>
      <a href="https://wa.me/5548984586949">Contato</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">{data.availLabel}</span>
      <a href={data.langPT} class:list={[!data.isEN && "lang-active"]}>PT</a>
      <a href={data.langEN} class:list={[data.isEN && "lang-active"]}>EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Quer tirar sua ideia do papel com
        <strong>engenharia bem feita?</strong>
        Me conte contexto, restrições e objetivo.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Engenheiro de Software</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
