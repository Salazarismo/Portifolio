---
import BaseLayout from "../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Case de Produto",
  heroTitleTop: "Plataforma",
  heroTitleEm: "Nexus",
  heroSubtitle: "Plataforma de ingressos com vendas via WhatsApp, pagamentos integrados e operação de check‑in resiliente em eventos.",
  heroImage: "https://victor-alcantara.vercel.app/images/98f5ae2c-0f91-4fda-9e44-1fd81a607417.png",
  heroFilter: "grayscale(.6) brightness(.3)",
  langPT: "/projects/p7/",
  langEN: "/en/projects/p7/",
  availLabel: "Disponível 2026",
  isEN: false,
  heroStats: [
    { key: "Escopo", value: "Full-stack · Arquitetura" },
    { key: "Stack", value: "NestJS · PostgreSQL · WhatsApp · Mercado Pago" },
    { key: "Código", value: "Privado (NDA)" },
    { key: "KPI", value: "Check-in 100% offline" }
  ],
  heroActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Ver Evidências", href: "#evidence" },
    { label: "Código (NDA)", href: "#code" }
  ],
  tldrTitle: "TL;DR — 1 minuto",
  tldrCards: [
    { key: "Problema", value: "Venda e check-in dependentes de <strong>canais fragmentados</strong> e de rede estável na portaria em uma operação crítica." },
    { key: "Solução", value: "Fluxo via <strong>WhatsApp + backend multi-tenant</strong> + check-in offline-first com fila local e sincronização em lote." },
    { key: "Resultado", value: "Portaria opera <strong>sem internet</strong> com sync segura e menos incidentes em dia de evento." }
  ],
  noticeTitle: "Código privado (NDA).",
  noticeBody: "Este software está em produção e sob propriedade de uma empresa. Acesso a material sanitizado pode ser solicitado diretamente.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Papel", value: "Full-stack, NestJS + React/Next." },
    { key: "Escala", value: "Multi-tenant, múltiplas organizações com operação simultânea." },
    { key: "Restrições", value: "Portaria offline; idempotência e rastreabilidade obrigatórias nas integrações." }
  ],
  problemTitle: "Problema & Impacto",
  problemItems: [
    { key: "Sintoma", value: "A portaria <strong>trava sem rede</strong> e a operação perde fluidez justamente no momento de maior pressão." },
    { key: "Causa", value: "Ausência de um mecanismo <strong>offline-first com fila e retry controlado</strong> para a operação crítica." },
    { key: "Impacto", value: "<strong>Risco operacional alto</strong>, divergências por reprocessamento e aumento de suporte em dia de evento." }
  ],
  approachTitle: "Abordagem",
  approachSteps: [
    { title: "Vendas", text: "WhatsApp Cloud API com orquestração multi-tenant para reduzir passos na compra e manter contexto por organização." },
    { title: "Pagamentos", text: "Mercado Pago com rotas administrativas para operação, conciliação e suporte sem espalhar regras críticas pelo front-end." },
    { title: "Offline-first", text: "IndexedDB + sync em lote para reduzir rajadas na reconexão e manter a portaria utilizável mesmo sem internet." }
  ],
  reliabilityTitle: "Confiabilidade",
  reliabilityCards: [
    { key: "Riscos", value: "Duplicidade em retry, rajadas na reconexão e inconsistência operacional entre dispositivos." },
    { key: "Garantias", value: "Idempotência por externalId e fila local com retry controlado e sincronização em lote." },
    { key: "Evidência", value: "Snippet real do mecanismo de fila/sync utilizado na operação offline." }
  ],
  codeBlock: {
    lang: "JS · Node.js",
    html: `<span class="kw">await</span> db<span class="pu">.</span><span class="fn">add</span><span class="pu">(</span><span class="str">'syncQueue'</span><span class="pu">,</span> <span class="pu">{</span>
  url<span class="pu">,</span>
  method<span class="pu">,</span>
  body<span class="pu">,</span>
  timestamp<span class="pu">:</span> Date<span class="pu">.</span><span class="fn">now</span><span class="pu">(),</span>
  retryCount<span class="pu">:</span> <span class="kw">0</span>
<span class="pu">});</span>
<span class="kw">await</span> <span class="fn">fetch</span><span class="pu">(</span>syncUrl<span class="pu">,</span> <span class="pu">{</span> method<span class="pu">:</span> <span class="str">'POST'</span><span class="pu">,</span> body<span class="pu">:</span> JSON<span class="pu">.</span><span class="fn">stringify</span><span class="pu">(</span><span class="pu">{</span> orders <span class="pu">}</span><span class="pu">)</span> <span class="pu">});</span>`
  },
  stackTags: ["NestJS", "PostgreSQL", "WhatsApp Cloud API", "Mercado Pago", "PWA", "IndexedDB"],
  extensionsTitle: "Extensões & Próximos passos",
  extensionsItems: [
    "Observabilidade da fila: pendentes, idade média e taxa de sincronização.",
    "Relatórios operacionais consolidados para check-in, POS e reconciliação.",
    "Métricas do funil WhatsApp → pagamento → emissão para identificar gargalos."
  ],
  ctaEyebrow: "Você tem esse problema?",
  ctaTitle: "Precisa vender com baixa fricção e operar em campo sem depender de internet?",
  ctaBody: "Desenho fluxo offline-first com idempotência, sync em lote e trilha de auditoria.",
  ctaActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Código (NDA)", href: "#code" },
    { label: "Evidências", href: "#evidence" }
  ],
  bottomNavBackLabel: "Voltar",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Topo",
  bottomNavNextLabel: "Próximo case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p3/"
};
---
<BaseLayout title="Plataforma Nexus — Victor de Alcântara" description="Plataforma de ingressos com vendas via WhatsApp, pagamentos integrados e operação de check‑in resiliente em eventos.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="/#projects">Projetos</a>
      <a href="/#sobre">Sobre</a>
      <a href="https://wa.me/5548984586949">Contato</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">{data.availLabel}</span>
      <a href={data.langPT} class:list={[!data.isEN && "lang-active"]}>PT</a>
      <a href={data.langEN} class:list={[data.isEN && "lang-active"]}>EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Quer tirar sua ideia do papel com
        <strong>engenharia bem feita?</strong>
        Me conte contexto, restrições e objetivo.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Engenheiro de Software</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
