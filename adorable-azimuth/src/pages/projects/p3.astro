---
import BaseLayout from "../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Case de Produto",
  heroTitleTop: "Habit",
  heroTitleEm: "Analyzer",
  heroSubtitle: "Aplicativo web de acompanhamento de hábitos com API REST e dashboard de visualização de progresso.",
  heroImage: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fm=jpg&w=1600&q=80",
  heroFilter: "grayscale(.8) brightness(.25)",
  heroStats: [
    { key: "Escopo", value: "Arquitetura + Full-stack" },
    { key: "Stack", value: "FastAPI · Next.js · PostgreSQL" },
    { key: "Código", value: "Público (GitHub)" },
    { key: "KPI", value: "−40% custo de leitura" }
  ],
  heroActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Ver Evidências", href: "#evidence" },
    { label: "Código Público ↗", href: "https://github.com/Salazarismo/habit_analyzer", target: "_blank", rel: "noopener noreferrer" }
  ],
  tldrTitle: "TL;DR — 1 minuto",
  tldrCards: [
    { key: "Problema", value: "Registrar hábitos e acompanhar evolução tende a virar <strong>planilha ou nota solta</strong>, com pouco insight e baixa consistência." },
    { key: "Solução", value: "Backend em <strong>FastAPI + JWT</strong> e frontend Next.js com fluxo de registro e gráficos por hábito." },
    { key: "Resultado", value: "MVP funcional com <strong>Docker Compose, OpenAPI e testes</strong>, além de otimização de leitura em janelas grandes." }
  ],
  noticeTitle: "Código público disponível no GitHub.",
  noticeBody: "Repositório com README, OpenAPI e evidências do fluxo principal.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Papel", value: "Arquitetura + Full-stack. API, autenticação, persistência e dashboard web." },
    { key: "Escala", value: "Múltiplos hábitos por usuário, registros diários e histórico suficiente para gráficos e tendências." },
    { key: "Restrições", value: "Consistência de datas e valores, autenticação segura e evolução do schema com migrações." }
  ],
  problemTitle: "Problema & Impacto",
  problemItems: [
    { key: "Sintoma", value: "Registro manual disperso e <strong>pouca visibilidade do progresso</strong> ao longo do tempo." },
    { key: "Causa", value: "Dados sem modelo único e sem uma <strong>visualização agregada</strong> do histórico por hábito." },
    { key: "Impacto", value: "Baixa aderência ao acompanhamento e <strong>decisões piores sobre rotina</strong> por falta de sinal." }
  ],
  approachTitle: "Abordagem",
  approachSteps: [
    { title: "Modelar", text: "Estruturar hábitos, registros e resumos analíticos em Postgres com contratos claros para persistência e evolução via migrações." },
    { title: "Expor", text: "Disponibilizar uma API REST com FastAPI, autenticação JWT e documentação Swagger/OpenAPI para reduzir atrito de integração." },
    { title: "Visualizar", text: "Entregar dashboard web em Next.js com registro rápido, gráficos por hábito e leitura eficiente de janelas temporais maiores." }
  ],
  reliabilityTitle: "Confiabilidade",
  reliabilityCards: [
    { key: "Riscos", value: "Dados inconsistentes, regressão de autenticação e divergência entre resumo e série temporal." },
    { key: "Garantias", value: "Pydantic para validação, Alembic para migrações e testes unitários + E2E no fluxo crítico." },
    { key: "Evidência", value: "Trecho da estratégia de resumo com cache versionado e fallback entre leitura direta e pré-agregada." }
  ],
  codeBlock: {
    lang: "Python · FastAPI",
    html: `<span class="kw">def</span> <span class="fn">get_habit_summary</span><span class="pu">(</span>self<span class="pu">,</span> user_id<span class="pu">,</span> habit_id<span class="pu">,</span> days<span class="pu">=</span><span class="kw">30</span><span class="pu">):</span>
    cache_key <span class="pu">=</span> <span class="pu">(</span><span class="fn">str</span><span class="pu">(</span>user_id<span class="pu">),</span> <span class="fn">str</span><span class="pu">(</span>habit_id<span class="pu">),</span> days<span class="pu">,</span> <span class="fn">int</span><span class="pu">(</span>habit<span class="pu">.</span>summary_version <span class="kw">or</span> <span class="kw">0</span><span class="pu">))</span>
    use_daily <span class="pu">=</span> settings<span class="pu">.</span>USE_SUMMARY_DAILY <span class="kw">and</span> days <span class="pu">&lt;=</span> settings<span class="pu">.</span>SUMMARY_WINDOW_DAYS
    <span class="kw">if</span> use_daily<span class="pu">:</span>
        rows <span class="pu">=</span> self<span class="pu">.</span>record_repo<span class="pu">.</span><span class="fn">get_summary_daily</span><span class="pu">(</span>habit_id<span class="pu">,</span> start_date<span class="pu">,</span> end_date<span class="pu">)</span>
    <span class="kw">else</span><span class="pu">:</span>
        records <span class="pu">=</span> self<span class="pu">.</span>record_repo<span class="pu">.</span><span class="fn">get_by_date_range</span><span class="pu">(</span>habit_id<span class="pu">,</span> start_date<span class="pu">,</span> end_date<span class="pu">)</span>
    <span class="kw">return</span> result`
  },
  stackTags: ["FastAPI", "Next.js", "PostgreSQL", "JWT", "Alembic", "Playwright"],
  extensionsTitle: "Extensões & Próximos passos",
  extensionsItems: [
    "Adicionar metas, streaks e lembretes para reforçar aderência.",
    "Expandir relatórios semanais e mensais com filtros por hábito.",
    "Incluir observabilidade de API e erros para evolução segura do produto."
  ],
  ctaEyebrow: "Você tem esse problema?",
  ctaTitle: "Precisa de um MVP com API, autenticação e dashboard de visualização?",
  ctaBody: "Desenho a arquitetura, implemento o fluxo crítico e valido a entrega com documentação e testes.",
  ctaActions: [
    { label: "Falar no WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Código Público ↗", href: "https://github.com/Salazarismo/habit_analyzer", target: "_blank", rel: "noopener noreferrer" },
    { label: "Evidências", href: "#evidence" }
  ],
  bottomNavBackLabel: "Voltar",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Topo",
  bottomNavNextLabel: "Próximo case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p5/"
};
---
<BaseLayout title="Habit Analyzer — Victor de Alcântara" description="Aplicativo web de acompanhamento de hábitos com API REST e dashboard de visualização de progresso.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="https://victor-alcantara.vercel.app/#projects">Projetos</a>
      <a href="#">Sobre</a>
      <a href="https://wa.me/5548984586949">Contato</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">Disponível para projetos em 2026</span>
      <a href="/projects/p3/" class="lang-active">PT</a>
      <a href="/en/projects/p3/">EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Quer tirar sua ideia do papel com
        <strong>engenharia bem feita?</strong>
        Me conte contexto, restrições e objetivo.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Engenheiro de Software</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
