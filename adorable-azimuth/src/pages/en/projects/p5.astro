---
import BaseLayout from "../../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Product Case",
  heroTitleTop: "Relatorium",
  heroTitleEm: "UI Quick Activity Button",
  heroSubtitle: "Flutter app for rural management with a dashboard and quick shortcuts to start flows — activities, soil, budgeting, and more.",
  heroImage: "https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fm=jpg&w=1600&q=80",
  heroFilter: "grayscale(.8) brightness(.25)",
  heroStats: [
    { key: "Scope", value: "UI Component + Dashboard" },
    { key: "Stack", value: "Flutter · go_router" },
    { key: "Code", value: "Private code (NDA)" },
    { key: "Critical shortcuts", value: "6 actions in 1 click" }
  ],
  heroActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "View Evidence", href: "#evidence" },
    { label: "Private code (NDA)", href: "#code" }
  ],
  tldrTitle: "TL;DR — 1 minute",
  tldrCards: [
    { key: "Problem", value: "Starting frequent flows — activity, soil, budgeting — required <strong>extra navigation</strong> before reaching the action." },
    { key: "Solution", value: "Standardized shortcuts with <strong>QuickActionButton</strong> + Semantics + Tooltip and named-route navigation (go_router)." },
    { key: "Result", value: "A dashboard with <strong>consistent and accessible quick entry points</strong> for creating records and reaching key screens." }
  ],
  noticeTitle: "Private code (NDA).",
  noticeBody: "This software is in production and owned by a company. Access to sanitized material can be requested directly.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Role / scope", value: "Cross-platform Flutter. Scope: UI component + dashboard integration." },
    { key: "Scale", value: "Dashboard shortcuts across multiple modules — Activities, Soil, Finance, Pests & Diseases." },
    { key: "Constraints", value: "Accessibility (Semantics), feedback (Tooltip), and consistent navigation through named routes." }
  ],
  problemTitle: "Problem & Impact",
  problemItems: [
    { key: "Symptom", value: "Quick create and access actions were <strong>scattered across screens and menus</strong>, delaying the start of the flow." },
    { key: "Cause", value: "Lack of a <strong>reusable shortcuts pattern</strong> with consistent dashboard navigation." },
    { key: "Impact", value: "More steps to start frequent records and a <strong>higher chance of navigation drift</strong>." }
  ],
  approachTitle: "Approach",
  approachSteps: [
    { title: "Identify", text: "Map actions that start frequent flows in the dashboard — create activity, soil analysis, budgeting — and prioritize them by usage frequency." },
    { title: "Encapsulate", text: "Consolidate them into a <code style='font-family:var(--mono);font-size:.85em;color:var(--amber-soft)'>QuickActionButton</code> with Semantics and Tooltip — a single UI + accessibility standard, reusable across modules." },
    { title: "Navigate", text: "Integrate named routes via go_router to keep navigation predictable and eliminate ambiguity between screens." }
  ],
  reliabilityTitle: "Reliability",
  reliabilityCards: [
    { key: "Risks", value: "Invisible shortcuts for accessibility, inconsistent navigation, and flow regressions." },
    { key: "Guarantees", value: "Semantics defines role and label; Tooltip provides context; named routes reduce drift." },
    { key: "Evidence", value: "Component implementation and usage in DashboardPage with pushNamed for named routes." }
  ],
  codeBlock: {
    lang: "Dart · Flutter",
    html: `<span class="kw">Semantics</span><span class="pu">(</span>
  button<span class="pu">:</span> <span class="kw">true</span><span class="pu">,</span>
  label<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
  child<span class="pu">:</span> <span class="kw">Tooltip</span><span class="pu">(</span>
    message<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
    child<span class="pu">:</span> <span class="fn">QuickActionButton</span><span class="pu">(</span>
      label<span class="pu">:</span>          <span class="str">'Nova atividade'</span><span class="pu">,</span>
      icon<span class="pu">:</span>           Icons<span class="pu">.</span>event_available<span class="pu">,</span>
      semanticsLabel<span class="pu">:</span> <span class="str">'Nova atividade'</span><span class="pu">,</span>
      onPressed<span class="pu">:</span> <span class="pu">()</span> <span class="pu">=></span> context<span class="pu">.</span><span class="fn">pushNamed</span><span class="pu">(</span>AppRoutes<span class="pu">.</span>newActivity<span class="pu">),</span>
    <span class="pu">),</span>
  <span class="pu">),</span>
<span class="pu">);</span>`
  },
  stackTags: ["Flutter", "Semantics", "Tooltip", "go_router", "Named routes"],
  extensionsTitle: "Extensions & Next steps",
  extensionsItems: [
    "Allow dashboard shortcut configuration — which actions appear and in what order.",
    "Add keyboard and focus shortcuts for desktop without losing mobile consistency.",
    "Expand widget tests covering Semantics, Tooltip, and named-route navigation."
  ],
  ctaEyebrow: "Do you have this problem?",
  ctaTitle: "Need to reduce daily steps without breaking accessibility?",
  ctaBody: "I redesign flows and implement reusable shortcuts with consistent navigation — and deliver evidence for each decision.",
  ctaActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Private code (NDA)", href: "#code" },
    { label: "Evidence", href: "#evidence" }
  ],
  bottomNavBackLabel: "Back",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Top",
  bottomNavNextLabel: "Next case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p7/"
};
---
<BaseLayout title="Relatorium — UI Quick Activity Button — Victor de Alcântara" description="Flutter app for rural management with a dashboard and quick shortcuts to start flows.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="https://victor-alcantara.vercel.app/#projects">Projects</a>
      <a href="#">About</a>
      <a href="https://wa.me/5548984586949">Contact</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">Available for projects in 2026</span>
      <a href="/projects/p5/">PT</a>
      <a href="/en/projects/p5/" class="lang-active">EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Want to turn your idea into reality with
        <strong>solid engineering?</strong>
        Share context, constraints, and goals with me.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Software Engineer</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
