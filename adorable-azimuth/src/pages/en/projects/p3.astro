---
import BaseLayout from "../../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Product Case",
  heroTitleTop: "Habit",
  heroTitleEm: "Analyzer",
  heroSubtitle: "Web app for habit tracking with a REST API and a dashboard for progress visualization.",
  heroImage: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fm=jpg&w=1600&q=80",
  heroFilter: "grayscale(.8) brightness(.25)",
  langPT: "/projects/p3/",
  langEN: "/en/projects/p3/",
  availLabel: "Available for projects in 2026",
  isEN: true,
  heroStats: [
    { key: "Scope", value: "Architecture + Full-stack" },
    { key: "Stack", value: "FastAPI · Next.js · PostgreSQL" },
    { key: "Code", value: "Public (GitHub)" },
    { key: "KPI", value: "−40% read cost" }
  ],
  heroActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "View Evidence", href: "#evidence" },
    { label: "Public Code ↗", href: "https://github.com/Salazarismo/habit_analyzer", target: "_blank", rel: "noopener noreferrer" }
  ],
  tldrTitle: "TL;DR — 1 minute",
  tldrCards: [
    { key: "Problem", value: "Tracking habits and progress often turns into a <strong>spreadsheet or loose notes</strong>, with little insight and low consistency." },
    { key: "Solution", value: "Backend in <strong>FastAPI + JWT</strong> and a Next.js frontend with logging flows and habit charts." },
    { key: "Result", value: "A functional MVP with <strong>Docker Compose, OpenAPI, and tests</strong>, plus optimized reads on large time windows." }
  ],
  noticeTitle: "Public code available on GitHub.",
  noticeBody: "Repository with README, OpenAPI, and evidence of the main flow.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Role", value: "Architecture + Full-stack. API, authentication, persistence, and web dashboard." },
    { key: "Scale", value: "Multiple habits per user, daily records, and enough history for charts and trends." },
    { key: "Constraints", value: "Consistent dates and values, secure authentication, and schema evolution with migrations." }
  ],
  problemTitle: "Problem & Impact",
  problemItems: [
    { key: "Symptom", value: "Scattered manual logging and <strong>little visibility into progress</strong> over time." },
    { key: "Cause", value: "Data without a single model and without an <strong>aggregated view</strong> of habit history." },
    { key: "Impact", value: "Lower adherence to tracking and <strong>worse routine decisions</strong> due to weak signal." }
  ],
  approachTitle: "Approach",
  approachSteps: [
    { title: "Model", text: "Structure habits, records, and analytic summaries in Postgres with clear persistence contracts and migration paths." },
    { title: "Expose", text: "Provide a REST API with FastAPI, JWT authentication, and Swagger/OpenAPI docs to reduce integration friction." },
    { title: "Visualize", text: "Deliver a Next.js web dashboard with fast logging, per-habit charts, and efficient reads for larger time windows." }
  ],
  reliabilityTitle: "Reliability",
  reliabilityCards: [
    { key: "Risks", value: "Inconsistent data, authentication regressions, and divergence between summaries and time series." },
    { key: "Guarantees", value: "Pydantic validation, Alembic migrations, and unit + E2E tests on the critical flow." },
    { key: "Evidence", value: "A summary strategy snippet with versioned cache and fallback between direct and pre-aggregated reads." }
  ],
  codeBlock: {
    lang: "Python · FastAPI",
    html: `<span class="kw">def</span> <span class="fn">get_habit_summary</span><span class="pu">(</span>self<span class="pu">,</span> user_id<span class="pu">,</span> habit_id<span class="pu">,</span> days<span class="pu">=</span><span class="kw">30</span><span class="pu">):</span>
    cache_key <span class="pu">=</span> <span class="pu">(</span><span class="fn">str</span><span class="pu">(</span>user_id<span class="pu">),</span> <span class="fn">str</span><span class="pu">(</span>habit_id<span class="pu">),</span> days<span class="pu">,</span> <span class="fn">int</span><span class="pu">(</span>habit<span class="pu">.</span>summary_version <span class="kw">or</span> <span class="kw">0</span><span class="pu">))</span>
    use_daily <span class="pu">=</span> settings<span class="pu">.</span>USE_SUMMARY_DAILY <span class="kw">and</span> days <span class="pu">&lt;=</span> settings<span class="pu">.</span>SUMMARY_WINDOW_DAYS
    <span class="kw">if</span> use_daily<span class="pu">:</span>
        rows <span class="pu">=</span> self<span class="pu">.</span>record_repo<span class="pu">.</span><span class="fn">get_summary_daily</span><span class="pu">(</span>habit_id<span class="pu">,</span> start_date<span class="pu">,</span> end_date<span class="pu">)</span>
    <span class="kw">else</span><span class="pu">:</span>
        records <span class="pu">=</span> self<span class="pu">.</span>record_repo<span class="pu">.</span><span class="fn">get_by_date_range</span><span class="pu">(</span>habit_id<span class="pu">,</span> start_date<span class="pu">,</span> end_date<span class="pu">)</span>
    <span class="kw">return</span> result`
  },
  stackTags: ["FastAPI", "Next.js", "PostgreSQL", "JWT", "Alembic", "Playwright"],
  extensionsTitle: "Extensions & Next steps",
  extensionsItems: [
    "Add goals, streaks, and reminders to improve adherence.",
    "Expand weekly and monthly reports with per-habit filters.",
    "Add API and error observability for safer product evolution."
  ],
  ctaEyebrow: "Do you have this problem?",
  ctaTitle: "Need an MVP with API, authentication, and a visualization dashboard?",
  ctaBody: "I design the architecture, implement the critical flow, and validate delivery with documentation and tests.",
  ctaActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Public Code ↗", href: "https://github.com/Salazarismo/habit_analyzer", target: "_blank", rel: "noopener noreferrer" },
    { label: "Evidence", href: "#evidence" }
  ],
  bottomNavBackLabel: "Back",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Top",
  bottomNavNextLabel: "Next case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p5/"
};
---
<BaseLayout title="Habit Analyzer — Victor de Alcântara" description="Web app for habit tracking with a REST API and a dashboard for progress visualization.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="/#projects">Projects</a>
      <a href="/en/#sobre">About</a>
      <a href="https://wa.me/5548984586949">Contact</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">{data.availLabel}</span>
      <a href={data.langPT} class:list={[!data.isEN && "lang-active"]}>PT</a>
      <a href={data.langEN} class:list={[data.isEN && "lang-active"]}>EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Want to turn your idea into reality with
        <strong>solid engineering?</strong>
        Share context, constraints, and goals with me.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Software Engineer</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
