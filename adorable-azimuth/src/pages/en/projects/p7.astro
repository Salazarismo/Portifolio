---
import BaseLayout from "../../../components/BaseLayout.astro";
import ProjectCaseRedesign from "../../../components/ProjectCaseRedesign.astro";

export const prerender = false;

const data = {
  heroEyebrow: "Product Case",
  heroTitleTop: "Nexus",
  heroTitleEm: "Platform",
  heroSubtitle: "Ticketing platform with WhatsApp sales, integrated payments, and resilient event check-in operations.",
  heroImage: "https://victor-alcantara.vercel.app/images/98f5ae2c-0f91-4fda-9e44-1fd81a607417.png",
  heroFilter: "grayscale(.6) brightness(.3)",
  langPT: "/projects/p7/",
  langEN: "/en/projects/p7/",
  availLabel: "Available for projects in 2026",
  isEN: true,
  heroStats: [
    { key: "Scope", value: "Full-stack · Architecture" },
    { key: "Stack", value: "NestJS · PostgreSQL · WhatsApp · Mercado Pago" },
    { key: "Code", value: "Private code (NDA)" },
    { key: "KPI", value: "100% offline check-in" }
  ],
  heroActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "View Evidence", href: "#evidence" },
    { label: "Private code (NDA)", href: "#code" }
  ],
  tldrTitle: "TL;DR — 1 minute",
  tldrCards: [
    { key: "Problem", value: "Sales and check-in depended on <strong>fragmented channels</strong> and stable internet at the gate during a critical operation." },
    { key: "Solution", value: "<strong>WhatsApp flow + multi-tenant backend</strong> + offline-first check-in with a local queue and batch sync." },
    { key: "Result", value: "The gate operates <strong>without internet</strong> with safe sync and fewer incidents on event day." }
  ],
  noticeTitle: "Private code (NDA).",
  noticeBody: "This software is in production and owned by a company. Access to sanitized material can be requested directly.",
  snapshotTitle: "Snapshot",
  snapshotRows: [
    { key: "Role", value: "Full-stack, NestJS + React/Next." },
    { key: "Scale", value: "Multi-tenant, multiple organizations running operations simultaneously." },
    { key: "Constraints", value: "Offline gate operations; idempotency and traceability are mandatory across integrations." }
  ],
  problemTitle: "Problem & Impact",
  problemItems: [
    { key: "Symptom", value: "The gate <strong>freezes without connectivity</strong>, and operations lose fluency exactly when pressure is highest." },
    { key: "Cause", value: "Lack of an <strong>offline-first mechanism with queue and controlled retry</strong> for the critical operation." },
    { key: "Impact", value: "<strong>High operational risk</strong>, reprocessing inconsistencies, and increased support on event day." }
  ],
  approachTitle: "Approach",
  approachSteps: [
    { title: "Sales", text: "WhatsApp Cloud API with multi-tenant orchestration to reduce purchase steps and preserve context per organization." },
    { title: "Payments", text: "Mercado Pago with admin routes for operations, reconciliation, and support without spreading critical rules across the front end." },
    { title: "Offline-first", text: "IndexedDB + batch sync to reduce reconnect spikes and keep the gate usable even without internet." }
  ],
  reliabilityTitle: "Reliability",
  reliabilityCards: [
    { key: "Risks", value: "Duplicate retries, reconnect spikes, and operational inconsistency across devices." },
    { key: "Guarantees", value: "Idempotency through externalId and a local queue with controlled retry and batch synchronization." },
    { key: "Evidence", value: "A real snippet of the queue/sync mechanism used in offline operations." }
  ],
  codeBlock: {
    lang: "JS · Node.js",
    html: `<span class="kw">await</span> db<span class="pu">.</span><span class="fn">add</span><span class="pu">(</span><span class="str">'syncQueue'</span><span class="pu">,</span> <span class="pu">{</span>
  url<span class="pu">,</span>
  method<span class="pu">,</span>
  body<span class="pu">,</span>
  timestamp<span class="pu">:</span> Date<span class="pu">.</span><span class="fn">now</span><span class="pu">(),</span>
  retryCount<span class="pu">:</span> <span class="kw">0</span>
<span class="pu">});</span>
<span class="kw">await</span> <span class="fn">fetch</span><span class="pu">(</span>syncUrl<span class="pu">,</span> <span class="pu">{</span> method<span class="pu">:</span> <span class="str">'POST'</span><span class="pu">,</span> body<span class="pu">:</span> JSON<span class="pu">.</span><span class="fn">stringify</span><span class="pu">(</span><span class="pu">{</span> orders <span class="pu">}</span><span class="pu">)</span> <span class="pu">});</span>`
  },
  stackTags: ["NestJS", "PostgreSQL", "WhatsApp Cloud API", "Mercado Pago", "PWA", "IndexedDB"],
  extensionsTitle: "Extensions & Next steps",
  extensionsItems: [
    "Queue observability: pending items, average age, and synchronization rate.",
    "Consolidated operational reports for check-in, POS, and reconciliation.",
    "WhatsApp → payment → issuance funnel metrics to identify bottlenecks."
  ],
  ctaEyebrow: "Do you have this problem?",
  ctaTitle: "Need low-friction sales and field operations that do not depend on internet?",
  ctaBody: "I design offline-first flows with idempotency, batch sync, and audit trails.",
  ctaActions: [
    { label: "Message on WhatsApp ↗", href: "https://wa.me/5548984586949", primary: true },
    { label: "Private code (NDA)", href: "#code" },
    { label: "Evidence", href: "#evidence" }
  ],
  bottomNavBackLabel: "Back",
  bottomNavBackHref: "https://victor-alcantara.vercel.app/#projects",
  bottomNavTopLabel: "Top",
  bottomNavNextLabel: "Next case",
  bottomNavNextHref: "https://victor-alcantara.vercel.app/projects/p3/"
};
---
<BaseLayout title="Nexus Platform — Victor de Alcântara" description="Ticketing platform with WhatsApp sales, integrated payments, and resilient event check-in operations.">
  <Fragment slot="nav">
    <a href="https://victor-alcantara.vercel.app/" class="nav-logo">Victor<sup>®</sup></a>
    <div class="nav-center">
      <a href="/#projects">Projects</a>
      <a href="/en/#sobre">About</a>
      <a href="https://wa.me/5548984586949">Contact</a>
    </div>
    <div class="nav-right">
      <span class="avail-dot">{data.availLabel}</span>
      <a href={data.langPT} class:list={[!data.isEN && "lang-active"]}>PT</a>
      <a href={data.langEN} class:list={[data.isEN && "lang-active"]}>EN</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">↗ Email</a>
    </div>
  </Fragment>
  <ProjectCaseRedesign {...data} />
  <Fragment slot="footer">
    <div class="footer-cta">
      <p class="footer-cta-text">
        Want to turn your idea into reality with
        <strong>solid engineering?</strong>
        Share context, constraints, and goals with me.
      </p>
      <div class="footer-contact">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="footer-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary" style="margin-top:8px">
          WhatsApp ↗
        </a>
      </div>
    </div>
    <div class="footer-bar">
      <div class="footer-id">
        <span class="footer-name">Victor de Alcântara Bueno</span>
        <span class="footer-role">Software Engineer</span>
      </div>
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/victor-de-alcantara/">LinkedIn</a>
        <a href="https://github.com/Salazarismo">GitHub</a>
        <a href="https://wa.me/5548984586949">WhatsApp</a>
      </div>
      <span class="footer-copy">© 2026 Victor</span>
    </div>
  </Fragment>
</BaseLayout>
