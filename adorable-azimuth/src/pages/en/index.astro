---
import BaseLayout from "../../components/BaseLayout.astro";
import HomeHybridLanding from "../../components/HomeHybridLanding.astro";

const data = {
  logoHref: "/en/",
  ptHref: "/",
  enHref: "/en/",
  isEN: true,
  eyebrow: "Software Engineer",
  title: "Full-Stack · Offline-First · Critical Integrations",
  description: "I build web and mobile products focused on operational reliability, consistent field experience, and integrations that don't fail under pressure.",
  recruiterTag: "→ Recruiters & Hiring Managers",
  recruiterHeadline: "I'm looking for a role",
  recruiterSub: "Resume, technical case studies, and full professional profile.",
  recruiterArrow: "View professional profile →",
  recruiterHref: "/en/recruiter",
  clientTag: "→ Clients & Projects",
  clientHeadline: "I have a project in mind",
  clientSub: "Case studies, stack, approach, and direct contact for scoping.",
  clientArrow: "View projects →",
  clientHref: "/en/projects/p7/",
  footerEmailLabel: "Email",
  footerCopy: "© 2026 Victor de Alcântara Bueno"
};
---
<BaseLayout
  title="Victor de Alcântara Bueno — Software Engineer"
  description="Software Engineer specialized in offline-first products, critical integrations, and operational UX."
>
  <Fragment slot="nav">
    <a class="nav-logo" href={data.logoHref}>Victor<span>®</span></a>
    <div class="nav-lang">
      <a href={data.ptHref}>PT</a>
      <span>/</span>
      <a href={data.enHref} class="active">EN</a>
    </div>
  </Fragment>

  <HomeHybridLanding {...data} />

  <Fragment slot="footer">
    <div class="footer-links">
      <a href="https://linkedin.com/in/victor-de-alcantara/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://github.com/Salazarismo" target="_blank" rel="noopener">GitHub</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com">{data.footerEmailLabel}</a>
    </div>
    <span class="footer-copy">{data.footerCopy}</span>
  </Fragment>
</BaseLayout>
