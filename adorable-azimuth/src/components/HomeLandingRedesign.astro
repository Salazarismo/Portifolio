---
type ProjectCard = {
  href: string;
  image: string;
  alt: string;
  year: string;
  badge: string;
  titleHtml: string;
  kpi: string;
  tags: string[];
  cta: string;
};

type Props = {
  projectsId: string;
  aboutId: string;
  contactId: string;
  heroEyebrow: string;
  heroNameTop: string;
  heroNameEm: string;
  heroRole: string;
  heroTagline: string;
  heroPrimaryCta: string;
  heroSecondaryCta: string;
  heroTertiaryCta: string;
  heroBar: { label: string; value: string }[];
  scrollCue: string;
  stackItems: string[];
  projectsTitle: string;
  projects: ProjectCard[];
  aboutTitle: string;
  aboutTextHtml: string;
  aboutTechLabel: string;
  aboutFindMeLabel: string;
  aboutLinks: { label: string; href: string }[];
  contactTitle: string;
  contactHeadlineHtml: string;
  contactBody: string;
  contactPrimaryCta: string;
  contactSecondaryCta: string;
  backTop: string;
};

const props = Astro.props as Props;
---
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap');

  body.page-home {
    --bg:         #080807;
    --bg-card:    #111110;
    --bg-card2:   #161614;
    --border:     #222220;
    --border-dim: #1a1a18;
    --text:       #EDE9E1;
    --text-dim:   #7A7871;
    --text-muted: #3F3E3A;
    --amber:      #C8923A;
    --amber-soft: #D4A85A;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans:  'Syne', system-ui, sans-serif;
    --mono:  'JetBrains Mono', monospace;
  }

  body.page-home {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.6;
    overflow-x: hidden;
  }
  body.page-home::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: .6;
  }
  body.page-home a { color: inherit; text-decoration: none; }
  body.page-home img { display: block; max-width: 100%; }
  body.page-home .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .7s ease, transform .7s ease;
  }
  body.page-home .reveal.visible { opacity: 1; transform: none; }
  body.page-home .reveal-delay-1 { transition-delay: .1s; }
  body.page-home .reveal-delay-2 { transition-delay: .2s; }
  body.page-home .reveal-delay-3 { transition-delay: .3s; }
  body.page-home nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 60px;
    background: rgba(8,8,7,.7);
    backdrop-filter: blur(18px) saturate(1.4);
    border-bottom: 1px solid var(--border-dim);
  }
  body.page-home .nav-logo {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: .04em;
    color: var(--text);
  }
  body.page-home .nav-logo sup { font-size: .55em; opacity: .6; }
  body.page-home .nav-center {
    display: flex;
    gap: 28px;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  body.page-home .nav-center a:hover { color: var(--text); }
  body.page-home .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  body.page-home .nav-right a { transition: color .2s; }
  body.page-home .nav-right a:hover { color: var(--amber); }
  body.page-home .lang-active { color: var(--text) !important; }
  body.page-home .avail-dot {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: .65rem;
    color: var(--text-dim);
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  body.page-home .avail-dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5DC275;
    box-shadow: 0 0 8px #5DC275;
    flex-shrink: 0;
  }
  body.page-home .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 60px 80px 0;
    position: relative;
    overflow: hidden;
  }
  body.page-home .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 50% at 80% 20%, rgba(200,146,58,.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 10% 80%, rgba(200,146,58,.04) 0%, transparent 55%),
      radial-gradient(ellipse 100% 80% at 50% 100%, rgba(8,8,7,1) 0%, transparent 60%);
  }
  body.page-home .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 1100px;
  }
  body.page-home .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 28px;
  }
  body.page-home .hero-eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }
  body.page-home .hero-name {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 8vw, 7.5rem);
    font-weight: 300;
    line-height: .98;
    letter-spacing: -.02em;
    color: var(--text);
  }
  body.page-home .hero-name em {
    font-style: italic;
    color: var(--amber-soft);
    display: block;
  }
  body.page-home .hero-role {
    margin-top: 28px;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .hero-tagline {
    margin-top: 20px;
    font-size: 1rem;
    color: var(--text-dim);
    max-width: 440px;
    line-height: 1.7;
  }
  body.page-home .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 36px;
  }
  body.page-home .hero-bar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 72px;
    padding: 28px 0;
    border-top: 1px solid var(--border-dim);
  }
  body.page-home .hero-bar-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 36px;
    border-right: 1px solid var(--border-dim);
  }
  body.page-home .hero-bar-item:first-child { padding-left: 0; }
  body.page-home .hero-bar-item:last-child { border-right: none; }
  body.page-home .hero-bar-label {
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .hero-bar-value {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--text-dim);
  }
  body.page-home .scroll-cue {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 24px 0 48px;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--amber), transparent);
    animation: scrollpulse 2s ease-in-out infinite;
  }
  @keyframes scrollpulse {
    0%, 100% { opacity: .4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }
  body.page-home .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-family: var(--sans);
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    border-radius: 3px;
    transition: all .22s ease;
    cursor: pointer;
    border: none;
  }
  body.page-home .btn-primary { background: var(--amber); color: #0A0908; }
  body.page-home .btn-primary:hover { background: var(--amber-soft); transform: translateY(-1px); }
  body.page-home .btn-ghost { background: transparent; color: var(--text-dim); border: 1px solid var(--border); }
  body.page-home .btn-ghost:hover { border-color: var(--text-muted); color: var(--text); }
  body.page-home .stack-strip {
    border-top: 1px solid var(--border-dim);
    border-bottom: 1px solid var(--border-dim);
    overflow: hidden;
    padding: 0;
    background: var(--bg-card);
    position: relative;
  }
  body.page-home .stack-strip::before,
  body.page-home .stack-strip::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  body.page-home .stack-strip::before { left: 0; background: linear-gradient(to right, var(--bg-card), transparent); }
  body.page-home .stack-strip::after { right: 0; background: linear-gradient(to left, var(--bg-card), transparent); }
  body.page-home .stack-track {
    display: flex;
    gap: 0;
    animation: marquee 28s linear infinite;
    width: max-content;
  }
  body.page-home .stack-strip:hover .stack-track { animation-play-state: paused; }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  body.page-home .stack-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    font-family: var(--mono);
    font-size: .68rem;
    letter-spacing: .08em;
    color: var(--text-muted);
    border-right: 1px solid var(--border-dim);
    white-space: nowrap;
    transition: color .2s;
  }
  body.page-home .stack-item:hover { color: var(--amber); }
  body.page-home .stack-item::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background .2s;
  }
  body.page-home .stack-item:hover::before { background: var(--amber); }
  body.page-home .section-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 80px;
  }
  body.page-home .s-head {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-dim);
  }
  body.page-home .s-num {
    font-family: var(--mono);
    font-size: .65rem;
    color: var(--text-muted);
    letter-spacing: .1em;
    flex-shrink: 0;
    padding-top: 4px;
  }
  body.page-home .s-title {
    font-family: var(--serif);
    font-size: 2.4rem;
    font-weight: 300;
    letter-spacing: -.01em;
    color: var(--text);
  }
  body.page-home #projects { padding: 100px 0 0; }
  body.page-home .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-dim);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    overflow: hidden;
  }
  body.page-home .project-card {
    position: relative;
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    cursor: pointer;
    transition: background .3s;
  }
  body.page-home .project-card:hover { background: var(--bg-card2); }
  body.page-home .project-card-img {
    position: relative;
    height: 220px;
    overflow: hidden;
  }
  body.page-home .project-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(.7) brightness(.6);
    transition: filter .5s ease, transform .6s ease;
  }
  body.page-home .project-card:hover .project-card-img img {
    filter: grayscale(.3) brightness(.8);
    transform: scale(1.04);
  }
  body.page-home .project-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%);
    transition: background .3s;
  }
  body.page-home .project-card:hover .project-card-img-overlay {
    background: linear-gradient(to bottom, transparent 40%, var(--bg-card2) 100%);
  }
  body.page-home .project-card-body {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  body.page-home .project-card-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .project-badge {
    padding: 2px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--amber);
    border-color: rgba(200,146,58,.3);
  }
  body.page-home .project-card-title {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 300;
    line-height: 1.15;
    color: var(--text);
  }
  body.page-home .project-card-kpi {
    font-size: .82rem;
    color: var(--text-dim);
    line-height: 1.5;
  }
  body.page-home .project-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  body.page-home .project-tag {
    font-family: var(--mono);
    font-size: .6rem;
    letter-spacing: .06em;
    color: var(--text-muted);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  body.page-home .project-card-link {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--border-dim);
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color .2s, gap .2s;
  }
  body.page-home .project-card:hover .project-card-link {
    color: var(--amber);
    gap: 12px;
  }
  body.page-home .project-card-link svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    transition: transform .2s;
  }
  body.page-home .project-card:hover .project-card-link svg { transform: translateX(3px); }
  body.page-home #sobre { padding: 100px 0; }
  body.page-home .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  body.page-home .sobre-text {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-dim);
  }
  body.page-home .sobre-text strong { color: var(--text); font-weight: 400; }
  body.page-home .sobre-right {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  body.page-home .sobre-detail-label {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }
  body.page-home .sobre-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  body.page-home .sobre-tech {
    font-family: var(--mono);
    font-size: .68rem;
    letter-spacing: .06em;
    color: var(--text-dim);
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 2px;
    transition: all .2s;
  }
  body.page-home .sobre-tech:hover { border-color: var(--amber); color: var(--amber); }
  body.page-home .sobre-divider {
    width: 100%;
    height: 1px;
    background: var(--border-dim);
  }
  body.page-home .sobre-links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  body.page-home #contato {
    border-top: 1px solid var(--border-dim);
    padding: 100px 0 0;
  }
  body.page-home .contato-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 80px;
    align-items: start;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--border-dim);
  }
  body.page-home .contato-headline {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--text);
    max-width: 540px;
  }
  body.page-home .contato-headline em { font-style: italic; color: var(--amber-soft); }
  body.page-home .contato-body {
    font-size: .9rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 440px;
    margin-top: 20px;
  }
  body.page-home .contato-right {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
    padding-top: 8px;
  }
  body.page-home .contato-email {
    font-family: var(--mono);
    font-size: .78rem;
    color: var(--amber);
    letter-spacing: .04em;
    transition: opacity .2s;
  }
  body.page-home .contato-email:hover { opacity: .75; }
  body.page-home footer {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  body.page-home .footer-id {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  body.page-home .footer-name {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text-dim);
  }
  body.page-home .footer-role {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .footer-links {
    display: flex;
    gap: 20px;
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  body.page-home .footer-links a:hover { color: var(--text); }
  body.page-home .footer-copy {
    font-family: var(--mono);
    font-size: .65rem;
    color: var(--text-muted);
  }
  body.page-home .back-top {
    display: block;
    text-align: center;
    padding: 20px;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-top: 1px solid var(--border-dim);
    transition: color .2s;
  }
  body.page-home .back-top:hover { color: var(--text); }
  @media (max-width: 900px) {
    body.page-home nav { padding: 0 20px; }
    body.page-home .nav-center { display: none; }
    body.page-home .hero { padding: 60px 24px 0; }
    body.page-home .section-wrap { padding: 0 24px; }
    body.page-home .projects-grid { grid-template-columns: 1fr; }
    body.page-home .sobre-grid { grid-template-columns: 1fr; gap: 48px; }
    body.page-home .contato-inner { grid-template-columns: 1fr; gap: 40px; }
    body.page-home .contato-right { align-items: flex-start; }
    body.page-home .hero-bar { flex-direction: column; gap: 0; }
    body.page-home .hero-bar-item { border-right: none; border-bottom: 1px solid var(--border-dim); padding: 14px 0; }
    body.page-home footer { flex-direction: column; gap: 20px; align-items: flex-start; padding: 28px 24px; }
  }
</style>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow reveal">{props.heroEyebrow}</div>
    <h1 class="hero-name reveal reveal-delay-1">
      <span set:html={props.heroNameTop}></span>
      <em>{props.heroNameEm}</em>
    </h1>
    <p class="hero-role reveal reveal-delay-2">{props.heroRole}</p>
    <p class="hero-tagline reveal reveal-delay-2">{props.heroTagline}</p>
    <div class="hero-actions reveal reveal-delay-3">
      <a href="#projects" class="btn btn-primary">{props.heroPrimaryCta}</a>
      <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="btn btn-ghost">↗ Email</a>
      <a href="https://wa.me/5548984586949" class="btn btn-ghost">{props.heroTertiaryCta}</a>
    </div>
  </div>
  <div class="hero-bar reveal">
    {props.heroBar.map((item) => (
      <div class="hero-bar-item">
        <span class="hero-bar-label">{item.label}</span>
        <span class="hero-bar-value">{item.value}</span>
      </div>
    ))}
  </div>
  <div class="scroll-cue reveal">
    <div class="scroll-line"></div>
    {props.scrollCue}
  </div>
</section>

<div class="stack-strip">
  <div class="stack-track">
    {[...props.stackItems, ...props.stackItems].map((item) => <span class="stack-item">{item}</span>)}
  </div>
</div>

<section id={props.projectsId}>
  <div class="section-wrap">
    <div class="s-head reveal">
      <span class="s-num">01</span>
      <h2 class="s-title">{props.projectsTitle}</h2>
    </div>
    <div class="projects-grid">
      {props.projects.map((project, index) => (
        <a href={project.href} class:list={["project-card", "reveal", index === 1 && "reveal-delay-1", index === 2 && "reveal-delay-2"]}>
          <div class="project-card-img">
            <img src={project.image} alt={project.alt} loading="lazy" />
            <div class="project-card-img-overlay"></div>
          </div>
          <div class="project-card-body">
            <div class="project-card-eyebrow">
              {project.year}
              <span class="project-badge">{project.badge}</span>
            </div>
            <h3 class="project-card-title" set:html={project.titleHtml}></h3>
            <p class="project-card-kpi">{project.kpi}</p>
            <div class="project-card-tags">
              {project.tags.map((tag) => <span class="project-tag">{tag}</span>)}
            </div>
            <div class="project-card-link">
              {project.cta}
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 6h8M6 2l4 4-4 4"></path>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section id={props.aboutId}>
  <div class="section-wrap">
    <div class="s-head reveal">
      <span class="s-num">02</span>
      <h2 class="s-title">{props.aboutTitle}</h2>
    </div>
    <div class="sobre-grid">
      <p class="sobre-text reveal" set:html={props.aboutTextHtml}></p>
      <div class="sobre-right reveal reveal-delay-1">
        <div>
          <div class="sobre-detail-label">{props.aboutTechLabel}</div>
          <div class="sobre-techs">
            {props.stackItems.slice(0, 8).map((item) => <span class="sobre-tech">{item}</span>)}
          </div>
        </div>
        <div class="sobre-divider"></div>
        <div>
          <div class="sobre-detail-label">{props.aboutFindMeLabel}</div>
          <div class="sobre-links">
            {props.aboutLinks.map((link) => (
              <a href={link.href} class="btn btn-ghost">{link.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id={props.contactId}>
  <div class="section-wrap">
    <div class="s-head reveal">
      <span class="s-num">03</span>
      <h2 class="s-title">{props.contactTitle}</h2>
    </div>
    <div class="contato-inner">
      <div class="reveal">
        <h2 class="contato-headline" set:html={props.contactHeadlineHtml}></h2>
        <p class="contato-body">{props.contactBody}</p>
      </div>
      <div class="contato-right reveal reveal-delay-1">
        <a href="mailto:victor.de.alcantara.bueno@gmail.com" class="contato-email">
          victor.de.alcantara.bueno@gmail.com
        </a>
        <a href="https://wa.me/5548984586949" class="btn btn-primary">
          {props.contactPrimaryCta}
        </a>
        <a href="https://www.linkedin.com/in/victor-de-alcantara/" class="btn btn-ghost">
          {props.contactSecondaryCta}
        </a>
      </div>
    </div>
  </div>
</section>

<a href="#top" class="back-top">{props.backTop}</a>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    }),
    { threshold: 0.07, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  const navLinks = document.querySelectorAll('.nav-center a');
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        navLinks.forEach(l => l.style.color = '');
        const active = document.querySelector(`.nav-center a[href="#${e.target.id}"]`);
        if (active) active.style.color = 'var(--text)';
      }
    });
  }, { rootMargin: '-40% 0px -50% 0px' });
  document.querySelectorAll('section[id]').forEach(s => io.observe(s));
</script>
