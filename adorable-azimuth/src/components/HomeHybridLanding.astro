---
type Props = {
  logoHref: string;
  ptHref: string;
  enHref: string;
  isEN?: boolean;
  eyebrow: string;
  title: string;
  description: string;
  recruiterTag: string;
  recruiterHeadline: string;
  recruiterSub: string;
  recruiterArrow: string;
  recruiterHref: string;
  clientTag: string;
  clientHeadline: string;
  clientSub: string;
  clientArrow: string;
  clientHref: string;
  footerEmailLabel: string;
  footerCopy: string;
};

const props = Astro.props as Props;
---
<style is:global>
  body.page-home {
    --charcoal:    #1a1a1a;
    --charcoal-2:  #222222;
    --charcoal-3:  #2e2e2e;
    --amber:       #c8922a;
    --amber-light: #e0a83a;
    --gold:        #d4a843;
    --off-white:   #f0ece4;
    --muted:       #7a7570;
    --border:      rgba(200, 146, 42, 0.18);
    --border-dim:  rgba(255,255,255,0.07);
    background: var(--charcoal);
    color: var(--off-white);
    font-family: 'Syne', sans-serif;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  body.page-home::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  body.page-home nav[aria-label="Principal"] {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.5rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border-dim);
    background: rgba(26,26,26,0.85);
    backdrop-filter: blur(12px);
  }

  body.page-home .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--off-white);
    text-decoration: none;
    opacity: 0.8;
  }
  body.page-home .nav-logo span { color: var(--amber); }

  body.page-home .nav-lang {
    display: flex;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }
  body.page-home .nav-lang a {
    color: var(--muted);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  body.page-home .nav-lang a:hover,
  body.page-home .nav-lang a.active { color: var(--amber); }
  body.page-home .nav-lang span { color: var(--border); }

  body.page-home main#main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  body.page-home main#main::after {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(200,146,42,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  body.page-home .hero {
    text-align: center;
    max-width: 780px;
    width: 100%;
    position: relative;
  }

  body.page-home .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: homeFadeUp 0.6s ease forwards 0.1s;
  }

  body.page-home .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--off-white);
    margin-bottom: 0.3rem;
    opacity: 0;
    animation: homeFadeUp 0.7s ease forwards 0.2s;
  }

  body.page-home .hero-name em {
    font-style: italic;
    color: var(--amber-light);
  }

  body.page-home .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2.2rem;
    opacity: 0;
    animation: homeFadeUp 0.7s ease forwards 0.3s;
  }

  body.page-home .hero-divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    margin: 0 auto 2.2rem;
    opacity: 0;
    animation: homeFadeIn 0.8s ease forwards 0.4s;
  }

  body.page-home .hero-description {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(240,236,228,0.75);
    max-width: 560px;
    margin: 0 auto 3.5rem;
    opacity: 0;
    animation: homeFadeUp 0.7s ease forwards 0.5s;
  }

  body.page-home .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    opacity: 0;
    animation: homeFadeUp 0.8s ease forwards 0.65s;
  }

  body.page-home .cta-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 2rem 1.8rem;
    border: 1px solid var(--border-dim);
    text-decoration: none;
    background: rgba(255,255,255,0.025);
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
    overflow: hidden;
    cursor: pointer;
  }

  body.page-home .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s;
  }

  body.page-home .cta-card--recruiter::before {
    background: linear-gradient(135deg, rgba(200,146,42,0.08), transparent 60%);
  }

  body.page-home .cta-card--client::before {
    background: linear-gradient(135deg, rgba(255,255,255,0.04), transparent 60%);
  }

  body.page-home .cta-card:hover {
    border-color: rgba(200,146,42,0.45);
    background: rgba(255,255,255,0.04);
    transform: translateY(-2px);
  }

  body.page-home .cta-card:hover::before { opacity: 1; }

  body.page-home .cta-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1rem;
  }

  body.page-home .cta-card--client .cta-tag { color: var(--muted); }

  body.page-home .cta-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--off-white);
    margin-bottom: 0.75rem;
    flex: 1;
  }

  body.page-home .cta-sub {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  body.page-home .cta-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--amber);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.2s;
  }

  body.page-home .cta-card--client .cta-arrow { color: rgba(240,236,228,0.4); }
  body.page-home .cta-card:hover .cta-arrow { gap: 0.9rem; }

  body.page-home footer[role="contentinfo"] {
    position: relative;
    z-index: 1;
    padding: 1.8rem 2.5rem;
    border-top: 1px solid var(--border-dim);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  body.page-home .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  body.page-home .footer-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  body.page-home .footer-links a:hover { color: var(--amber); }

  body.page-home .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: rgba(122,117,112,0.5);
  }

  @keyframes homeFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes homeFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (max-width: 600px) {
    body.page-home nav[aria-label="Principal"] { padding: 1.2rem 1.5rem; }
    body.page-home main#main { padding: 7rem 1.25rem 3rem; }
    body.page-home .cta-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }
    body.page-home footer[role="contentinfo"] {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
    }
  }
</style>

<div class="hero">
  <p class="hero-eyebrow">{props.eyebrow}</p>
  <h1 class="hero-name">
    Victor <em>de Alcântara</em>
  </h1>
  <p class="hero-title">{props.title}</p>
  <div class="hero-divider"></div>
  <p class="hero-description">{props.description}</p>
  <div class="cta-grid">
    <a class="cta-card cta-card--recruiter" href={props.recruiterHref}>
      <span class="cta-tag">{props.recruiterTag}</span>
      <p class="cta-headline">{props.recruiterHeadline}</p>
      <p class="cta-sub">{props.recruiterSub}</p>
      <span class="cta-arrow">{props.recruiterArrow}</span>
    </a>

    <a class="cta-card cta-card--client" href={props.clientHref}>
      <span class="cta-tag">{props.clientTag}</span>
      <p class="cta-headline">{props.clientHeadline}</p>
      <p class="cta-sub">{props.clientSub}</p>
      <span class="cta-arrow">{props.clientArrow}</span>
    </a>
  </div>
</div>
